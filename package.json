{
  "name": "ckstats",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "NODE_OPTIONS='--max-old-space-size=6144' next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "seed": "ts-node -P tsconfig.scripts.json scripts/seed.ts",
    "update-users": "ts-node -P tsconfig.scripts.json scripts/updateUsers.ts",
    "cleanup": "ts-node -P tsconfig.scripts.json scripts/cleanOldStats.ts",
    "vacuum": "dotenv -e .env -- bash -c 'PGPASSWORD=\"$DB_PASSWORD\" psql -h \"$DB_HOST\" -p \"$DB_PORT\" -U \"$DB_USER\" -d \"$DB_NAME\" -f scripts/vacuum.sql'",
    "test": "jest",
    "test:watch": "jest --watch",
    "migration:run": "ts-node -P tsconfig.scripts.json ./scripts/migration.ts",
    "migration:run:skip": "ts-node -P tsconfig.scripts.json ./scripts/migration.ts --skip-initial"
  },
  "engines": {
    "node": ">=18.19.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@tanstack/react-query": "^5.99.0",
    "bitcoinjs-lib": "^7.0.1",
    "daisyui": "^4.12.24",
    "next": "^14.2.35",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.0",
      "base-x": "^4.0.1",
      "cross-spawn": "^7.0.5"
    }
  }
}
